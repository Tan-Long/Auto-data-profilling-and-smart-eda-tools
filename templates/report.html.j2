<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>VSF Data Quality Report</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%230f7664'/%3E%3Ctext x='16' y='21' text-anchor='middle' font-family='Arial,sans-serif' font-size='11' font-weight='700' fill='%23ffffff'%3EVSF%3C/text%3E%3C/svg%3E">
  <style>
    :root {
      --foreground-primary: #121817;
      --foreground-secondary: #46504d;
      --foreground-tertiary: #68736f;
      --surface-canvas: #f5f7f5;
      --surface-panel: #ffffff;
      --surface-overlay: #f9faf8;
      --surface-inset: #eef2ef;
      --border-subtle: #e3e8e4;
      --border-default: #cfd8d2;
      --accent: #0f7664;
      --accent-soft: rgba(15, 118, 100, 0.1);
      --success: #23764d;
      --warning: #9a5f00;
      --destructive: #b23b32;
      --info: #316596;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--surface-canvas);
      color: var(--foreground-primary);
      font: 16px/1.48 ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    main { width: min(1120px, calc(100% - 32px)); margin: 0 auto; padding: 24px 0 56px; }
    header, section {
      margin-bottom: 16px;
      padding: 20px;
      border: 1px solid var(--border-default);
      border-radius: 12px;
      background: var(--surface-panel);
      box-shadow: 0 1px 0 rgba(18, 24, 23, 0.04);
    }
    h1, h2, h3, p { margin-top: 0; }
    h1 { margin-bottom: 8px; font-size: 32px; line-height: 1.08; letter-spacing: 0; }
    h2 { margin-bottom: 14px; font-size: 23px; line-height: 1.2; }
    h3 { margin: 0 0 8px; font-size: 17px; }
    a { color: var(--accent); font-weight: 800; }
    code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 13px; }
    .eyebrow { margin-bottom: 6px; color: var(--foreground-tertiary); font-size: 12px; font-weight: 900; text-transform: uppercase; }
    .muted { color: var(--foreground-secondary); }
    .report-header-line {
      display: flex;
      min-width: 0;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
    }
    .readiness-badge {
      flex: 0 0 auto;
      padding: 7px 12px;
      border: 1px solid rgba(35, 118, 77, 0.28);
      border-radius: 999px;
      background: #eff8f3;
      color: #245f40;
      font-weight: 900;
    }
    .summary-strip,
    .visual-panel,
    .report-actions,
    .todo-stack,
    .artifact-grid {
      display: grid;
      gap: 12px;
    }
    .summary-strip {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid var(--border-subtle);
    }
    .summary-strip div,
    .todo-block,
    .artifact-link {
      min-width: 0;
    }
    .summary-strip strong {
      display: block;
      margin-bottom: 3px;
      font-size: 24px;
      line-height: 1;
      font-variant-numeric: tabular-nums;
      overflow-wrap: anywhere;
    }
    .summary-strip span,
    .visual-column > span {
      color: var(--foreground-tertiary);
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
    }
    .summary-strip p { margin: 0; color: var(--foreground-secondary); font-size: 14px; }
    .answer-table td:first-child { width: 28%; font-weight: 800; }
    .visual-panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 14px;
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      background: var(--surface-overlay);
    }
    .visual-column { min-width: 0; }
    .bar-list { display: grid; gap: 7px; }
    .bar-row { display: grid; grid-template-columns: minmax(142px, 0.7fr) minmax(120px, 1fr) minmax(54px, auto); gap: 10px; align-items: center; }
    .bar-label { min-width: 0; color: var(--foreground-primary); font-size: 14px; font-weight: 800; overflow-wrap: anywhere; }
    .bar-track { height: 12px; border-radius: 999px; background: var(--surface-inset); overflow: hidden; }
    .bar-fill { height: 100%; min-width: 3px; border-radius: 999px; background: var(--accent); }
    .bar-fill.warn { background: var(--warning); }
    .bar-fill.danger { background: var(--destructive); }
    .bar-value { color: var(--foreground-secondary); font: 800 13px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; text-align: right; }
    .chart-empty { margin: 0; color: var(--foreground-secondary); }
    .missing-table-list { display: grid; gap: 8px; }
    .missing-table-group {
      display: grid;
      gap: 6px;
      min-width: 0;
      padding: 9px 10px;
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      background: var(--surface-panel);
    }
    .missing-table-head,
    .missing-column-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) max-content;
      gap: 10px;
      align-items: center;
      min-width: 0;
    }
    .missing-table-head code { color: var(--foreground-primary); font-weight: 900; overflow-wrap: anywhere; }
    .missing-table-head span {
      color: var(--foreground-tertiary);
      font-size: 11px;
      font-weight: 900;
      text-transform: uppercase;
    }
    .missing-column-list { display: grid; gap: 4px; }
    .missing-column-row span {
      min-width: 0;
      color: var(--foreground-secondary);
      font-size: 13px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .missing-column-row code { color: var(--warning); font-size: 12px; font-weight: 900; text-align: right; }
    .pill {
      display: inline-flex;
      min-height: 24px;
      align-items: center;
      padding: 2px 8px;
      border: 1px solid var(--border-default);
      border-radius: 999px;
      background: var(--surface-panel);
      font: 900 12px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      white-space: nowrap;
    }
    .P0, .P1, .Blocked, .NOT_READY, .failed, .invalid { color: var(--destructive); border-color: rgba(178, 59, 50, 0.35); }
    .P2, .Needs, .WARN, .warning { color: var(--warning); border-color: rgba(154, 95, 0, 0.35); }
    .P3, .Clean, .READY, .valid, .completed { color: var(--success); border-color: rgba(35, 118, 77, 0.35); }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border: 1px solid var(--border-default); border-collapse: collapse; background: var(--surface-panel); }
    th, td { padding: 10px 11px; border-bottom: 1px solid var(--border-subtle); text-align: left; vertical-align: top; }
    th { background: var(--surface-inset); color: var(--foreground-secondary); font-size: 12px; font-weight: 900; text-transform: uppercase; }
    .fix-table td { font-size: 15px; }
    .fix-table td:nth-child(5) { min-width: 260px; }
    .sample-table { font-size: 13px; table-layout: auto; }
    .sample-table th, .sample-table td { padding: 8px 9px; }
    .sample-table th.highlighted,
    .sample-table td.highlighted {
      border-left: 2px solid rgba(178, 59, 50, 0.45);
      border-right: 2px solid rgba(178, 59, 50, 0.18);
      background: rgba(178, 59, 50, 0.09);
    }
    .sample-table th.highlighted {
      color: var(--destructive);
      background: rgba(178, 59, 50, 0.13);
    }
    .sample-link { margin: 0; font-size: 13px; }
    .sample-preview-row > td {
      padding: 0 11px 14px;
      border-bottom: 1px solid var(--border-default);
      background: var(--surface-panel);
    }
    .sample-preview {
      margin: 0;
      padding: 10px 12px 12px;
      border: 1px solid var(--border-default);
      border-radius: 8px;
      background: var(--surface-overlay);
    }
    .sample-preview > summary {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 900;
    }
    .sample-preview > summary:focus-visible { outline: 3px solid rgba(15, 118, 100, 0.28); outline-offset: 3px; }
    .sample-preview-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 8px 0 10px;
      color: var(--foreground-secondary);
      font-size: 12px;
    }
    .sample-preview-meta span {
      display: inline-flex;
      min-height: 24px;
      align-items: center;
      padding: 2px 8px;
      border: 1px solid var(--border-subtle);
      border-radius: 999px;
      background: var(--surface-panel);
    }
    .sample-preview-meta .highlight-note {
      color: var(--destructive);
      border-color: rgba(178, 59, 50, 0.28);
      background: rgba(178, 59, 50, 0.07);
      font-weight: 800;
    }
    .checklist { margin: 0; padding-left: 18px; }
    .checklist li + li { margin-top: 4px; }
    details.report-details {
      margin-top: 10px;
      padding: 10px 12px;
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      background: var(--surface-overlay);
    }
    details.report-details > summary { cursor: pointer; font-weight: 900; }
    details.report-details > summary:focus-visible { outline: 3px solid rgba(15, 118, 100, 0.28); outline-offset: 3px; }
    .todo-summary-cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 12px;
    }
    .todo-summary-cards div,
    .todo-card {
      min-width: 0;
      padding: 10px 12px;
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      background: var(--surface-overlay);
    }
    .todo-summary-cards strong {
      display: block;
      color: var(--foreground-primary);
      font-size: 22px;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .todo-summary-cards span,
    .todo-card span {
      color: var(--foreground-tertiary);
      font-size: 11px;
      font-weight: 900;
      text-transform: uppercase;
    }
    .todo-summary-cards p,
    .todo-card p {
      margin: 4px 0 0;
      color: var(--foreground-secondary);
      font-size: 13px;
      line-height: 1.38;
    }
    .todo-stack { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .todo-block {
      padding: 12px 0 0;
      border-top: 1px solid var(--border-subtle);
    }
    .todo-card-list {
      display: grid;
      gap: 8px;
    }
    .todo-card header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin: 0 0 6px;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }
    .todo-card code {
      color: var(--accent);
      font-weight: 900;
    }
    .todo-card-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }
    .todo-card-meta span {
      padding: 3px 7px;
      border: 1px solid var(--border-subtle);
      border-radius: 999px;
      background: var(--surface-panel);
      color: var(--foreground-secondary);
      font-size: 11px;
      text-transform: none;
    }
    .todo-more {
      margin: 8px 0 0;
      padding: 8px 10px;
      border: 1px dashed var(--border-default);
      border-radius: 8px;
      background: var(--surface-panel);
      color: var(--foreground-secondary);
      font-size: 13px;
    }
    .artifact-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .artifact-link { display: grid; gap: 3px; color: var(--foreground-primary); text-decoration: none; }
    .artifact-link code { color: var(--foreground-tertiary); overflow-wrap: anywhere; }
    @media (max-width: 900px) {
      main { width: min(100% - 20px, 1120px); padding-top: 12px; }
      .report-header-line { display: grid; }
      .summary-strip, .visual-panel, .todo-summary-cards, .todo-stack, .artifact-grid { grid-template-columns: 1fr; }
      .bar-row { grid-template-columns: minmax(0, 1fr); }
      .bar-value { text-align: left; }
    }
  </style>
</head>
<body>
  <main>
    <header>
      <div class="report-header-line">
        <div>
          <p class="eyebrow">VSF Data Profiler</p>
          <h1>Data Quality Report</h1>
          <p class="muted">Visual CSV+DBML readiness report generated from deterministic local artifacts.</p>
        </div>
        <span class="readiness-badge">{{ visual_report.verdict }}</span>
      </div>
      <div class="summary-strip" aria-label="Report summary">
        <div><strong>{{ visual_report.issue_count }}</strong><span>Issues</span><p>{{ visual_report.p0_p1_count }} P0/P1 blockers</p></div>
        <div><strong>{{ visual_report.risk_score }}/100</strong><span>Risk score</span><p>From deterministic gates</p></div>
        <div><strong>{{ visual_report.table_count }}</strong><span>Tables</span><p>{{ visual_report.column_count }} columns</p></div>
        <div><strong>{{ visual_report.row_count }}</strong><span>Rows checked</span><p>{{ fixed_report.run_summary.status }} run</p></div>
      </div>
    </header>

    <section id="run-summary">
      <h2>Run Summary</h2>
      <div class="table-wrap">
        <table class="answer-table">
          <thead><tr><th>Question</th><th>Answer</th><th>Evidence</th></tr></thead>
          <tbody>
            <tr><td>Can this dataset run analysis?</td><td><span class="pill {{ visual_report.can_run_analysis.status | replace(' ', '-') }}">{{ visual_report.can_run_analysis.answer or "Needs review." }}</span></td><td>{{ visual_report.can_run_analysis.explanation or "Gate evidence was unavailable." }}</td></tr>
            <tr><td>Can joins be trusted?</td><td><span class="pill {{ visual_report.can_trust_joins.status | replace(' ', '-') }}">{{ visual_report.can_trust_joins.answer or "Needs review." }}</span></td><td>{{ visual_report.can_trust_joins.explanation or "Gate evidence was unavailable." }}</td></tr>
            <tr><td>What should be fixed first?</td><td>{{ visual_report.p0_p1_count }} blockers</td><td>Start with the issue table below. It shows table, column, bad rows, sample rows, and first fix.</td></tr>
            <tr><td>Run metadata</td><td>{{ fixed_report.run_summary.status }}</td><td>{{ fixed_report.run_summary.duration_seconds or "unknown" }} seconds · preflight {{ fixed_report.run_summary.preflight_status }} · run <code>{{ fixed_report.run_summary.run_id or "unknown" }}</code></td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section id="visual-overview">
      <h2>Where are the problems?</h2>
      <div class="visual-panel">
        <div class="visual-column">
          <span>Issue severity</span>
          <div class="bar-list">
            {% for row in visual_report.severity_chart %}
            <div class="bar-row"><div class="bar-label">{{ row.severity }}</div><div class="bar-track"><div class="bar-fill {{ 'danger' if row.severity in ['P0','P1'] else 'warn' }}" style="width: {{ row.bar_width_pct }}%"></div></div><div class="bar-value">{{ row.count }}</div></div>
            {% endfor %}
          </div>
        </div>
        <div class="visual-column">
          <span>Issue types</span>
          <div class="bar-list">
            {% for row in visual_report.issue_type_chart %}
            <div class="bar-row"><div class="bar-label">{{ row.issue_type }}</div><div class="bar-track"><div class="bar-fill danger" style="width: {{ row.bar_width_pct }}%"></div></div><div class="bar-value">{{ row.count }}</div></div>
            {% endfor %}
          </div>
        </div>
        <div class="visual-column">
          <span>Missing values by table</span>
          {% if visual_report.missingness_table_groups %}
          <div class="missing-table-list">
            {% for group in visual_report.missingness_table_groups %}
            <div class="missing-table-group">
              <div class="missing-table-head"><code>{{ group.table }}</code><span>{{ group.null_count }} missing</span></div>
              <div class="missing-column-list">
                {% for column in group.columns %}
                <div class="missing-column-row"><span>{{ column.column }}</span><code>{{ column.null_count }}</code></div>
                {% endfor %}
              </div>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <p class="chart-empty">No missing-value columns were detected in the chart evidence.</p>
          {% endif %}
        </div>
        <div class="visual-column">
          <span>Outliers by column</span>
          {% if visual_report.outlier_chart %}
          <div class="bar-list">
            {% for row in visual_report.outlier_chart %}
            <div class="bar-row"><div class="bar-label">{{ row.field }}</div><div class="bar-track"><div class="bar-fill warn" style="width: {{ row.bar_width_pct }}%"></div></div><div class="bar-value">{{ row.outlier_count }}</div></div>
            {% endfor %}
          </div>
          {% else %}
          <p class="chart-empty">No IQR outlier columns were detected for this run.</p>
          {% endif %}
        </div>
      </div>
    </section>

    <section id="fix-first">
      <h2>What should be fixed first?</h2>
      <div class="table-wrap">
        <table class="fix-table">
          <thead><tr><th>Priority</th><th>Where</th><th>Problem</th><th>Affected</th><th>First fix</th><th>Evidence</th></tr></thead>
          <tbody>
            {% for card in visual_report.top_fix_cards %}
            <tr>
              <td><span class="pill {{ card.severity }}">{{ card.severity }}</span><br><code>{{ card.issue_id }}</code></td>
              <td><code>{{ card.field }}</code></td>
              <td>{{ card.issue_label }}<br><span class="muted">{{ card.category }}</span></td>
              <td>{{ card.bad_count }}/{{ card.total_count }} rows<br><span class="muted">{{ card.bad_rate_text }}</span></td>
              <td>{{ card.fix }}</td>
              <td>
                {% if card.sample_preview.available %}
                <span class="pill P2">Preview below</span>
                {% else %}
                <span class="muted">No sample rows</span>
                {% endif %}
              </td>
            </tr>
            {% if card.sample_preview.available %}
            <tr class="sample-preview-row">
              <td colspan="6">
                <details class="sample-preview" open>
                  <summary><span>Sample row preview</span><span>{{ card.field }}</span></summary>
                  <div class="sample-preview-meta">
                    <span><code>{{ card.sample_preview.path }}</code></span>
                    <span>{{ card.sample_preview.rows|length }} bounded row{{ "" if card.sample_preview.rows|length == 1 else "s" }}</span>
                    {% if card.sample_preview.highlight_headers %}
                    <span class="highlight-note">Highlighted: {{ card.sample_preview.highlight_headers|join(", ") }}</span>
                    {% endif %}
                  </div>
                  <div class="table-wrap">
                    <table class="sample-table">
                      <thead>
                        <tr>
                          {% for header in card.sample_preview.headers %}
                          <th class="{{ 'highlighted' if header in card.sample_preview.highlight_headers else '' }}">{{ header }}</th>
                          {% endfor %}
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in card.sample_preview.rows %}
                        <tr>
                          {% for header in card.sample_preview.headers %}
                          <td class="{{ 'highlighted' if header in card.sample_preview.highlight_headers else '' }}">{{ row[header] }}</td>
                          {% endfor %}
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </details>
              </td>
            </tr>
            {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>

    <section id="quality-gates">
      <h2>Quality Gates</h2>
      {% if fixed_report.quality_gates.available %}
      <div class="table-wrap">
        <table>
          <thead><tr><th>Gate</th><th>Status</th><th>Answer</th><th>Explanation</th><th>Next action</th></tr></thead>
          <tbody>
            {% for gate in fixed_report.quality_gates.gates %}
            <tr><td>{{ gate.label }}</td><td><span class="pill {{ gate.status | replace(' ', '-') }}">{{ gate.status }}</span></td><td>{{ fixed_report.quality_gates.answers[gate.gate_id].answer }}</td><td>{{ gate.explanation }}</td><td>{{ gate.recommended_next_action.label if gate.recommended_next_action else "" }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <details class="report-details">
        <summary>Gate evidence values</summary>
        {% for gate in fixed_report.quality_gates.gates %}
        <h3>{{ gate.label }}</h3>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Label</th><th>Raw value</th><th>Meaning</th></tr></thead>
            <tbody>
              {% for value in gate.evidence_values %}
              <tr><td>{{ value.label }}</td><td>{{ value.raw_value }}</td><td>{{ value.meaning }}</td></tr>
              {% else %}
              <tr><td>none</td><td>none</td><td>No evidence values were present for this gate.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% endfor %}
      </details>
      {% else %}
      <p>{{ fixed_report.quality_gates.message }}</p>
      {% endif %}
    </section>

    <section id="table-overview">
      <h2>Table Overview</h2>
      {% if fixed_report.table_overview.available %}
      <p class="muted">Tables: {{ fixed_report.table_overview.summary.table_count }} · Not ready: {{ fixed_report.table_overview.summary.not_ready_count }} · Warnings: {{ fixed_report.table_overview.summary.warn_count }} · Ready: {{ fixed_report.table_overview.summary.ready_count }}.</p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Table</th><th>Readiness</th><th>Health</th><th>Issues</th><th>Affected columns</th><th>First fix step</th></tr></thead>
          <tbody>
            {% for row in fixed_report.table_overview.rows %}
            <tr><td><code>{{ row.table }}</code></td><td><span class="pill {{ row.readiness }}">{{ row.readiness }}</span></td><td>{{ row.health_score }}</td><td>{{ row.issue_total }}</td><td>{{ row.affected_columns_text }}</td><td>{{ row.next_step }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <details class="report-details">
        <summary>Full table detail</summary>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Table</th><th>Role</th><th>Readiness</th><th>Health</th><th>Rows</th><th>Columns</th><th>Issues</th><th>Relationship risks</th><th>Affected columns</th><th>First fix step</th></tr></thead>
            <tbody>
              {% for row in fixed_report.table_overview.rows %}
              <tr><td><code>{{ row.table }}</code></td><td>{{ row.role }}</td><td><span class="pill {{ row.readiness }}">{{ row.readiness }}</span></td><td>{{ row.health_score }}</td><td>{{ row.row_count }}</td><td>{{ row.column_count }}</td><td>{{ row.issue_total }}</td><td>{{ row.relationship_risk_count }}</td><td>{{ row.affected_columns_text }}</td><td>{{ row.next_step }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </details>
      {% else %}
      <p>Table overview is unavailable because table profile evidence was missing.</p>
      {% endif %}
    </section>

    <section id="column-issue-matrix">
      <h2>Column Issue Matrix</h2>
      {% if fixed_report.column_issue_matrix.rows %}
      <div class="table-wrap">
        <table>
          <thead><tr><th>Table</th><th>Column</th><th>Status</th><th>Issue</th><th>Bad rows</th><th>Sample</th><th>What should be fixed?</th></tr></thead>
          <tbody>
            {% for row in visual_report.column_issue_rows %}
            <tr><td><code>{{ row.table }}</code></td><td><code>{{ row.column }}</code></td><td><span class="pill {{ row.status }}">{{ row.status }}</span></td><td><code>{{ row.issue_id }}</code> {{ row.issue_type }}</td><td>{{ row.bad_rows }}</td><td>{% if row.sample %}<code>{{ row.sample }}</code>{% else %}none{% endif %}</td><td>{{ row.fix }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
      <p>No column or table issues were generated for this run.</p>
      {% endif %}
    </section>

    <section id="issue-action-plans">
      <h2>Issue Action Plans</h2>
      {% if fixed_report.issue_action_plans.available and fixed_report.issue_action_plans.summary_rows %}
      <p class="muted">Plans: {{ fixed_report.issue_action_plans.summary.plan_count }} · human review: {{ fixed_report.issue_action_plans.summary.human_review_count }} · average actionability: {{ fixed_report.issue_action_plans.summary.average_actionability_score }}/100.</p>
      <p class="muted">Main report expands the first {{ fixed_report.issue_action_plans.display_limit }} highest-priority plans as visual fix cards above. Full deterministic action-plan evidence remains in <code>{{ fixed_report.issue_action_plans.path }}</code>.</p>
      {% if fixed_report.issue_action_plans.remaining_count > 0 %}
      <p class="muted">{{ fixed_report.issue_action_plans.remaining_count }} additional plans are available in <code>{{ fixed_report.issue_action_plans.path }}</code> and the issue todo summary.</p>
      {% endif %}
      <details class="report-details">
        <summary>Action plan table</summary>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Issue</th><th>Priority</th><th>Table</th><th>Columns</th><th>First fix</th><th>First verification</th><th>Metrics</th></tr></thead>
            <tbody>
              {% for row in fixed_report.issue_action_plans.summary_rows %}
              <tr><td><code>{{ row.issue_id }}</code> {{ row.issue_type }}</td><td>{{ row.priority }}</td><td><code>{{ row.table }}</code></td><td>{{ row.columns }}</td><td>{{ row.first_fix }}</td><td>{{ row.first_verify }}</td><td>coverage {{ row.evidence_coverage }}/100 · actionability {{ row.actionability }}/100</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </details>
      {% else %}
      <p>{{ fixed_report.issue_action_plans.message }}</p>
      {% endif %}
    </section>

    <section id="todos">
      <h2>Todos</h2>
      {% if fixed_report.todos.available %}
      <p class="muted">Issue-first todo queue. Full fix/verify checklist detail belongs in the issue detail drawer and <code>{{ fixed_report.todos.path }}</code>.</p>
      <div class="todo-summary-cards" aria-label="Todo summary">
        <div><strong>{{ fixed_report.todos.issue_count }}</strong><span>Issues</span><p>Grouped by selected issue, not by repeated todo text.</p></div>
        <div><strong>{{ fixed_report.todos.fix_occurrence_count }}/{{ fixed_report.todos.verify_occurrence_count }}</strong><span>Fix data / Verify after fix</span><p>Action counts from deterministic issue plans.</p></div>
      </div>
      <div class="todo-card-list issue-first">
        {% for row in fixed_report.todos.issue_rows %}
        <article class="todo-card issue-first-card">
          <header><code>{{ row.issue_id }}</code><span class="pill {{ row.severity }}">{{ row.severity }}</span></header>
          <p><strong>{{ row.field }}</strong> · {{ row.issue_type }}</p>
          <div class="todo-card-meta"><span>{{ row.fix_count }} fix data</span><span>{{ row.verify_count }} verify after fix</span></div>
        </article>
        {% else %}
        <p class="muted">No issue-specific todos were generated.</p>
        {% endfor %}
      </div>
      {% if fixed_report.todos.remaining_issue_count > 0 %}
      <p class="todo-more">{{ fixed_report.todos.remaining_issue_count }} additional issues have todo detail in <code>{{ fixed_report.todos.path }}</code>.</p>
      {% endif %}
      {% else %}
      <p>{{ fixed_report.todos.message }}</p>
      {% endif %}
    </section>

    <section id="developer-artifacts">
      <h2>Developer Artifacts</h2>
      <p class="muted">Raw JSON and runtime artifacts are listed here for debugging and package compatibility. Normal report reading should use the sections above.</p>
      <details class="report-details">
        <summary>Developer evidence and artifact links</summary>
        <ul class="checklist">
          {% if connector_metadata.available %}<li><strong>Connector Metadata</strong>: {{ connector_metadata.source_type }} source; tables={{ connector_metadata.table_count }}; raw_extracts_persisted={{ connector_metadata.raw_extracts_persisted }}; secrets_redacted={{ connector_metadata.secrets_redacted }} (<code>{{ connector_metadata.path }}</code>)</li>{% endif %}
          {% if lineage_graph.available %}<li><strong>Developer Runtime Context</strong>: {{ lineage_graph.artifact_count }} artifacts, {{ lineage_graph.stage_count }} stages, {{ lineage_graph.edge_count }} edges (<code>{{ lineage_graph.path }}</code>)</li>{% endif %}
          {% if schema_evaluation.available %}<li><strong>Schema Mapping Summary</strong>: mapped={{ schema_evaluation.mapped_table_count }}, missing={{ schema_evaluation.missing_table_count }}, methods={{ schema_evaluation.mapping_method_counts_text }} (<code>{{ schema_evaluation.path }}</code>)</li>{% endif %}
          {% if relationship_graph.available %}<li><strong>Relationship Cardinality Summary</strong>: {{ relationship_graph.cardinality_counts_text }}; junction tables={{ relationship_graph.junction_tables_text }} (<code>{{ relationship_graph.path }}</code>)</li>{% endif %}
          {% if execution_flow.available %}<li><strong>Execution Flow</strong>: {{ execution_flow.stages|length }} stages; status={{ execution_flow.status }} (<code>run_summary.json</code>, <code>run_events.jsonl</code>)</li>{% endif %}
          {% if l4_report.available %}<li><strong>LLM Output Validation</strong>: {{ l4_report.status_text }}; validates LLM text only, not data readiness; provider={{ l4_report.provider }}{% if l4_report.model %}; model={{ l4_report.model }}{% endif %}{% if l4_report.fallback_reason %}; fallback={{ l4_report.fallback_reason }}{% endif %}</li>{% endif %}
        </ul>
        <div class="artifact-grid">
          {% for artifact in fixed_report.developer_artifacts.artifacts %}
          <a class="artifact-link" href="{{ artifact.path }}"><strong>{{ artifact.name }}</strong><code>{{ artifact.path }}</code></a>
          {% else %}
          <p>No developer artifacts were listed.</p>
          {% endfor %}
        </div>
      </details>
    </section>

    {% if fixed_report.evaluation_summary.available %}
    <section id="evaluation-summary">
      <h2>Evaluation Summary</h2>
      <p>Evaluation status: {{ fixed_report.evaluation_summary.status }}</p>
    </section>
    {% endif %}
  </main>
</body>
</html>
