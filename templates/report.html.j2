</div>

<script>
function switchTab(id, btn) {
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  if(btn) btn.classList.add('active');
}

function toggleTheme() {
  var html = document.documentElement;
  var isDark = html.getAttribute('data-theme') === 'dark';
  html.setAttribute('data-theme', isDark ? 'light' : 'dark');
  document.getElementById('themeBtn').textContent = isDark ? '🌙 Dark' : '☀️ Light';
  localStorage.setItem('eda-theme', isDark ? 'light' : 'dark');
}

(function() {
  var saved = localStorage.getItem('eda-theme');
  if (saved === 'dark') {
    document.documentElement.setAttribute('data-theme','dark');
    var btn = document.getElementById('themeBtn');
    if(btn) btn.textContent = '☀️ Light';
  }
})();

function exportTableCSV(tableId, filename) {
  var tbl = document.getElementById(tableId);
  if (!tbl) return;
  var rows = [];
  tbl.querySelectorAll('tr').forEach(function(tr) {
    var cells = [];
    tr.querySelectorAll('th,td').forEach(function(td) {
      cells.push('"' + td.innerText.replace(/"/g, '""') + '"');
    });
    if (cells.length) rows.push(cells.join(','));
  });
  var csv = rows.join('\n');
  var blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  URL.revokeObjectURL(url);
}

// ER Diagram pan/zoom
(function() {
  var _pz = null;
  function _initPz() {
    var svg = document.querySelector('#er-container svg');
    if (!svg) { setTimeout(_initPz, 300); return; }
    svg.setAttribute('width', '100%');
    svg.setAttribute('height', '100%');
    svg.style.maxWidth = 'none';
    svg.style.overflow = 'visible';
    _pz = svgPanZoom(svg, {
      zoomEnabled: true, panEnabled: true,
      controlIconsEnabled: false,
      fit: true, center: true,
      minZoom: 0.2, maxZoom: 8,
      zoomScaleSensitivity: 0.3,
    });
    var con = document.getElementById('er-container');
    if(con) con.addEventListener('wheel', function(e) {
      e.preventDefault();
      if (e.deltaY < 0) _pz.zoomIn(); else _pz.zoomOut();
    }, {passive: false});
  }
  window.erZoomIn    = function() { if(_pz) _pz.zoomIn(); };
  window.erZoomOut   = function() { if(_pz) _pz.zoomOut(); };
  window.erZoomReset = function() { if(_pz) { _pz.fit(); _pz.center(); } };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { setTimeout(_initPz, 600); });
  } else {
    setTimeout(_initPz, 600);
  }
})();
</script>
</body>
</html>
