      <tr><td><span class="guide-sev sev-p2">P2 Trung bình</span></td><td>🟡</td><td>Ảnh hưởng một phần, cần review</td><td>Ghi nhận, xử lý khi có thể</td></tr>
      <tr><td><span class="guide-sev sev-p3">P3 Cảnh báo</span></td><td>🔵</td><td>Cần xác nhận với nghiệp vụ</td><td>Hỏi domain expert, document lại</td></tr>
