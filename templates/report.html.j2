<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>VSF Data Quality Report</title>
  <style>
    :root {
      --foreground-primary: #121817;
      --foreground-secondary: #46504d;
      --foreground-tertiary: #68736f;
      --surface-canvas: #f5f7f5;
      --surface-panel: #ffffff;
      --surface-overlay: #f9faf8;
      --surface-inset: #eef2ef;
      --border-subtle: #e3e8e4;
      --border-default: #cfd8d2;
      --accent: #0f7664;
      --success: #23764d;
      --warning: #9a5f00;
      --destructive: #b23b32;
      --info: #316596;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--surface-canvas);
      color: var(--foreground-primary);
      font: 14px/1.5 ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    main { width: min(1180px, calc(100% - 32px)); margin: 0 auto; padding: 24px 0 56px; }
    header, section {
      margin-bottom: 16px;
      padding: 18px;
      border: 1px solid var(--border-default);
      border-radius: 12px;
      background: var(--surface-panel);
    }
    h1, h2, h3, p { margin-top: 0; }
    h1 { margin-bottom: 8px; font-size: 32px; line-height: 1.08; letter-spacing: 0; }
    h2 { margin-bottom: 12px; font-size: 20px; line-height: 1.2; }
    h3 { margin: 18px 0 8px; font-size: 15px; }
    a { color: var(--accent); font-weight: 800; }
    code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 12px; }
    .eyebrow { margin-bottom: 6px; color: var(--foreground-tertiary); font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .muted { color: var(--foreground-secondary); }
    .answer-grid, .summary-grid, .artifact-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }
    .answer-card, .metric-card, .artifact-link {
      min-width: 0;
      padding: 12px;
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      background: var(--surface-overlay);
    }
    .answer-card strong, .metric-card strong { display: block; font-size: 22px; line-height: 1.05; overflow-wrap: anywhere; }
    .answer-card span, .metric-card span {
      color: var(--foreground-tertiary);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
    }
    .answer-card p, .metric-card p { margin: 6px 0 0; color: var(--foreground-secondary); font-size: 12px; }
    .answer-card.Blocked { border-left: 4px solid var(--destructive); }
    .answer-card.Clean { border-left: 4px solid var(--success); }
    .answer-card.Needs { border-left: 4px solid var(--warning); }
    .answer-card.Usable { border-left: 4px solid var(--warning); }
    .pill {
      display: inline-flex;
      min-height: 24px;
      align-items: center;
      padding: 2px 8px;
      border: 1px solid var(--border-default);
      border-radius: 999px;
      background: var(--surface-panel);
      font: 800 12px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      white-space: nowrap;
    }
    .P0, .P1, .Blocked, .NOT_READY, .failed, .invalid { color: var(--destructive); border-color: rgba(178, 59, 50, 0.35); }
    .P2, .Needs, .WARN, .warning { color: var(--warning); border-color: rgba(154, 95, 0, 0.35); }
    .P3, .Clean, .READY, .valid, .completed { color: var(--success); border-color: rgba(35, 118, 77, 0.35); }
    table { width: 100%; border: 1px solid var(--border-default); border-collapse: collapse; background: var(--surface-panel); }
    th, td { padding: 8px 9px; border-bottom: 1px solid var(--border-subtle); text-align: left; vertical-align: top; }
    th { background: var(--surface-inset); color: var(--foreground-secondary); font-size: 11px; font-weight: 800; text-transform: uppercase; }
    .table-wrap { overflow-x: auto; }
    .plan-card, .todo-block {
      margin-top: 10px;
      padding: 12px;
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      background: var(--surface-overlay);
    }
    .plan-card summary {
      cursor: pointer;
      font-weight: 800;
      color: var(--foreground-primary);
    }
    .plan-card summary:focus-visible {
      outline: 3px solid rgba(15, 118, 100, 0.28);
      outline-offset: 3px;
    }
    .plan-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
    .todo-stack { display: grid; gap: 10px; }
    .checklist { margin: 0; padding-left: 18px; }
    .checklist li + li { margin-top: 4px; }
    .artifact-link { display: grid; gap: 3px; text-decoration: none; }
    .artifact-link code { color: var(--foreground-tertiary); overflow-wrap: anywhere; }
    @media (max-width: 880px) {
      main { width: min(100% - 20px, 1180px); padding-top: 12px; }
      .answer-grid, .summary-grid, .artifact-grid, .plan-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main>
    <header>
      <p class="eyebrow">VSF Data Profiler</p>
      <h1>Data Quality Report</h1>
      <p class="muted">Deterministic CSV+DBML report generated from structured local artifacts.</p>
      <div class="summary-grid" aria-label="Run summary metrics">
        <article class="metric-card"><span>Readiness</span><strong>{{ fixed_report.run_summary.readiness }}</strong><p>risk {{ fixed_report.run_summary.risk_score }}</p></article>
        <article class="metric-card"><span>Issues</span><strong>{{ fixed_report.run_summary.issue_count }}</strong><p>{{ fixed_report.run_summary.p0_p1_count }} P0/P1 blockers</p></article>
        <article class="metric-card"><span>Tables</span><strong>{{ fixed_report.run_summary.table_count }}</strong><p>{{ fixed_report.run_summary.row_count }} rows · {{ fixed_report.run_summary.column_count }} columns</p></article>
      </div>
    </header>

    <section id="run-summary">
      <h2>Run Summary</h2>
      <div class="answer-grid">
        <article class="answer-card {{ fixed_report.run_summary.can_run_analysis.status | replace(' ', '-') }}">
          <span>Can this dataset run analysis?</span>
          <strong>{{ fixed_report.run_summary.can_run_analysis.answer or "Needs review." }}</strong>
          <p>{{ fixed_report.run_summary.can_run_analysis.explanation or "Gate evidence was unavailable." }}</p>
        </article>
        <article class="answer-card {{ fixed_report.run_summary.can_trust_joins.status | replace(' ', '-') }}">
          <span>Can joins be trusted?</span>
          <strong>{{ fixed_report.run_summary.can_trust_joins.answer or "Needs review." }}</strong>
          <p>{{ fixed_report.run_summary.can_trust_joins.explanation or "Gate evidence was unavailable." }}</p>
        </article>
        <article class="answer-card">
          <span>Preflight review</span>
          <strong>{{ fixed_report.run_summary.preflight_status }}</strong>
          <p>{{ fixed_report.run_summary.preflight_message }}</p>
        </article>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Run ID</th><th>Status</th><th>Duration seconds</th><th>Tables</th><th>Columns</th><th>Rows</th></tr></thead>
          <tbody><tr><td><code>{{ fixed_report.run_summary.run_id or "unknown" }}</code></td><td>{{ fixed_report.run_summary.status }}</td><td>{{ fixed_report.run_summary.duration_seconds or "unknown" }}</td><td>{{ fixed_report.run_summary.table_count }}</td><td>{{ fixed_report.run_summary.column_count }}</td><td>{{ fixed_report.run_summary.row_count }}</td></tr></tbody>
        </table>
      </div>
    </section>

    <section id="quality-gates">
      <h2>Quality Gates</h2>
      {% if fixed_report.quality_gates.available %}
      <p class="muted">Source: deterministic. Blocked gates: {{ fixed_report.quality_gates.summary.blocked_count or 0 }} of {{ fixed_report.quality_gates.summary.gate_count or fixed_report.quality_gates.gates|length }}.</p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Gate</th><th>Status</th><th>Answer</th><th>Explanation</th><th>Next action</th></tr></thead>
          <tbody>
            {% for gate in fixed_report.quality_gates.gates %}
            <tr><td>{{ gate.label }}</td><td><span class="pill {{ gate.status }}">{{ gate.status }}</span></td><td>{{ fixed_report.quality_gates.answers[gate.gate_id].answer }}</td><td>{{ gate.explanation }}</td><td>{{ gate.recommended_next_action.label if gate.recommended_next_action else "" }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% for gate in fixed_report.quality_gates.gates %}
      <h3>{{ gate.label }} Evidence Values</h3>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Label</th><th>Raw value</th><th>Meaning</th></tr></thead>
          <tbody>
            {% for value in gate.evidence_values %}
            <tr><td>{{ value.label }}</td><td>{{ value.raw_value }}</td><td>{{ value.meaning }}</td></tr>
            {% else %}
            <tr><td>none</td><td>none</td><td>No evidence values were present for this gate.</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endfor %}
      {% else %}
      <p>{{ fixed_report.quality_gates.message }}</p>
      {% endif %}
    </section>

    <section id="table-overview">
      <h2>Table Overview</h2>
      {% if fixed_report.table_overview.available %}
      <div class="table-wrap">
        <table>
          <thead><tr><th>Table</th><th>Role</th><th>Readiness</th><th>Health</th><th>Rows</th><th>Columns</th><th>Issues</th><th>Relationship risks</th><th>Affected columns</th><th>First fix step</th></tr></thead>
          <tbody>
            {% for row in fixed_report.table_overview.rows %}
            <tr><td><code>{{ row.table }}</code></td><td>{{ row.role }}</td><td><span class="pill {{ row.readiness }}">{{ row.readiness }}</span></td><td>{{ row.health_score }}</td><td>{{ row.row_count }}</td><td>{{ row.column_count }}</td><td>{{ row.issue_total }}</td><td>{{ row.relationship_risk_count }}</td><td>{{ row.affected_columns_text }}</td><td>{{ row.next_step }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
      <p>Table overview is unavailable because table profile evidence was missing.</p>
      {% endif %}
    </section>

    <section id="column-issue-matrix">
      <h2>Column Issue Matrix</h2>
      {% if fixed_report.column_issue_matrix.rows %}
      <div class="table-wrap">
        <table>
          <thead><tr><th>Field</th><th>Status</th><th>Issue</th><th>Severity</th><th>Bad rows</th><th>Meaning</th><th>What should be fixed?</th></tr></thead>
          <tbody>
            {% for row in fixed_report.column_issue_matrix.rows %}
            <tr><td><code>{{ row.field }}</code></td><td>{{ row.status }}</td><td><code>{{ row.issue_id }}</code> {{ row.issue_type }}</td><td><span class="pill {{ row.severity }}">{{ row.severity }}</span></td><td>{{ row.bad_rows }}</td><td>{{ row.meaning }}</td><td>{{ row.fix }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
      <p>No column or table issues were generated for this run.</p>
      {% endif %}
    </section>

    <section id="issue-action-plans">
      <h2>Issue Action Plans</h2>
      {% if fixed_report.issue_action_plans.available and fixed_report.issue_action_plans.summary_rows %}
      <p class="muted">Plans: {{ fixed_report.issue_action_plans.summary.plan_count }} · human review: {{ fixed_report.issue_action_plans.summary.human_review_count }} · average actionability: {{ fixed_report.issue_action_plans.summary.average_actionability_score }}/100.</p>
      <p class="muted">Main report expands the first {{ fixed_report.issue_action_plans.display_limit }} highest-priority plans. Full deterministic action-plan evidence remains in <code>{{ fixed_report.issue_action_plans.path }}</code>.</p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Issue</th><th>Priority</th><th>Table</th><th>Columns</th><th>First fix</th><th>First verification</th><th>Metrics</th></tr></thead>
          <tbody>
            {% for row in fixed_report.issue_action_plans.summary_rows %}
            <tr><td><code>{{ row.issue_id }}</code> {{ row.issue_type }}</td><td>{{ row.priority }}</td><td><code>{{ row.table }}</code></td><td>{{ row.columns }}</td><td>{{ row.first_fix }}</td><td>{{ row.first_verify }}</td><td>coverage {{ row.evidence_coverage }}/100 · actionability {{ row.actionability }}/100</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% if fixed_report.issue_action_plans.remaining_count > 0 %}
      <p class="muted">{{ fixed_report.issue_action_plans.remaining_count }} additional plans are available in <code>{{ fixed_report.issue_action_plans.path }}</code> and the todo exports.</p>
      {% endif %}
      {% for plan in fixed_report.issue_action_plans.display_plans %}
      <details class="plan-card">
        <summary>{{ plan.issue_id }} {{ plan.issue_type }} · {{ plan.priority }}</summary>
        <p><strong>Finding:</strong> {{ plan.finding_summary }}</p>
        <p><strong>Source:</strong> {{ plan.source }} · <strong>Table:</strong> <code>{{ plan.table }}</code></p>
        <h3>Finding Values</h3>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Finding value</th><th>Raw value</th><th>Meaning</th></tr></thead>
            <tbody>
              {% for value in plan.evidence_values %}
              <tr><td>{{ value.label }}</td><td>{{ value.raw_value }}</td><td>{{ value.meaning }}</td></tr>
              {% else %}
              <tr><td>none</td><td>none</td><td>No finding values were available.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% if plan.hidden_evidence_value_count > 0 %}
        <p class="muted">{{ plan.hidden_evidence_value_count }} additional finding values are available in <code>{{ fixed_report.issue_action_plans.path }}</code>.</p>
        {% endif %}
        <div class="plan-grid">
          <div><h3>Fix data checklist</h3><ul class="checklist">{% for item in plan.fix_data_checklist %}<li>{{ item }}</li>{% else %}<li>No deterministic fix checklist was generated.</li>{% endfor %}</ul></div>
          <div><h3>Verify after fix checklist</h3><ul class="checklist">{% for item in plan.verify_after_fix_checklist %}<li>{{ item }}</li>{% else %}<li>No deterministic verification checklist was generated.</li>{% endfor %}</ul></div>
          <div><h3>Guidelines</h3><ul class="checklist">{% for item in plan.guidelines %}<li>{{ item }}</li>{% else %}<li>No deterministic guidelines were generated.</li>{% endfor %}</ul></div>
          <div><h3>Metrics</h3><p>Evidence coverage: {{ plan.evidence_coverage.score }}/100. {{ plan.evidence_coverage.explanation }}</p><p>Actionability: {{ plan.actionability_score.score }}/100. {{ plan.actionability_score.explanation }}</p></div>
        </div>
      </details>
      {% endfor %}
      {% else %}
      <p>{{ fixed_report.issue_action_plans.message }}</p>
      {% endif %}
    </section>

    <section id="todos">
      <h2>Todos</h2>
      {% if fixed_report.todos.available %}
      <p class="muted">Todo groups: {{ fixed_report.todos.summary.todo_group_count }} · Fix data: {{ fixed_report.todos.summary.fix_data_group_count }} · Verify after fix: {{ fixed_report.todos.summary.verify_after_fix_group_count }}.</p>
      <p class="muted">This report shows the first {{ fixed_report.todos.display_limit }} todo groups per type. Full grouped todos remain in <code>{{ fixed_report.todos.path }}</code>.</p>
      <div class="todo-stack">
        <article class="todo-block">
          <h3>Fix data</h3>
          <ul class="checklist">
            {% for group in fixed_report.todos.fix_display_groups %}
            <li><strong>{{ group.todo_id }}</strong> {{ group.text }} ({{ group.occurrence_count }} occurrence{{ "" if group.occurrence_count == 1 else "s" }})</li>
            {% else %}
            <li>No Fix data todos were generated.</li>
            {% endfor %}
            {% if fixed_report.todos.fix_remaining_count > 0 %}
            <li>{{ fixed_report.todos.fix_remaining_count }} additional Fix data groups are available in <code>{{ fixed_report.todos.path }}</code>.</li>
            {% endif %}
          </ul>
        </article>
        <article class="todo-block">
          <h3>Verify after fix</h3>
          <ul class="checklist">
            {% for group in fixed_report.todos.verify_display_groups %}
            <li><strong>{{ group.todo_id }}</strong> {{ group.text }} ({{ group.occurrence_count }} occurrence{{ "" if group.occurrence_count == 1 else "s" }})</li>
            {% else %}
            <li>No Verify after fix todos were generated.</li>
            {% endfor %}
            {% if fixed_report.todos.verify_remaining_count > 0 %}
            <li>{{ fixed_report.todos.verify_remaining_count }} additional Verify after fix groups are available in <code>{{ fixed_report.todos.path }}</code>.</li>
            {% endif %}
          </ul>
        </article>
      </div>
      {% else %}
      <p>{{ fixed_report.todos.message }}</p>
      {% endif %}
    </section>

    <section id="developer-artifacts">
      <h2>Developer Artifacts</h2>
      <p class="muted">Raw JSON and runtime artifacts are listed here for debugging and package compatibility. Normal report reading should use the sections above.</p>
      {% if connector_metadata.available or lineage_graph.available or schema_evaluation.available or relationship_graph.available or execution_flow.available %}
      <article class="report-card">
        <h3>Developer Evidence Summary</h3>
        <ul class="checklist">
          {% if connector_metadata.available %}
          <li><strong>Connector Metadata</strong>: {{ connector_metadata.source_type }} source; tables={{ connector_metadata.table_count }}; raw_extracts_persisted={{ connector_metadata.raw_extracts_persisted }}; secrets_redacted={{ connector_metadata.secrets_redacted }} (<code>{{ connector_metadata.path }}</code>)</li>
          {% endif %}
          {% if lineage_graph.available %}
          <li><strong>Developer Runtime Context</strong>: {{ lineage_graph.artifact_count }} artifacts, {{ lineage_graph.stage_count }} stages, {{ lineage_graph.edge_count }} edges (<code>{{ lineage_graph.path }}</code>)</li>
          {% endif %}
          {% if schema_evaluation.available %}
          <li><strong>Schema Mapping Summary</strong>: mapped={{ schema_evaluation.mapped_table_count }}, missing={{ schema_evaluation.missing_table_count }}, methods={{ schema_evaluation.mapping_method_counts_text }} (<code>{{ schema_evaluation.path }}</code>)</li>
          {% endif %}
          {% if relationship_graph.available %}
          <li><strong>Relationship Cardinality Summary</strong>: {{ relationship_graph.cardinality_counts_text }}; junction tables={{ relationship_graph.junction_tables_text }} (<code>{{ relationship_graph.path }}</code>)</li>
          {% endif %}
          {% if execution_flow.available %}
          <li><strong>Execution Flow</strong>: {{ execution_flow.stages|length }} stages; status={{ execution_flow.status }} (<code>run_summary.json</code>, <code>run_events.jsonl</code>)</li>
          {% endif %}
        </ul>
      </article>
      {% endif %}
      {% if l4_report.available %}
      <article class="report-card">
        <h3>Compatibility LLM Guardrail Artifact</h3>
        <p>LLM guardrail status: <strong>{{ l4_report.status }}</strong> · provider={{ l4_report.provider }}{% if l4_report.model %} · model={{ l4_report.model }}{% endif %}{% if l4_report.fallback_reason %} · fallback={{ l4_report.fallback_reason }}{% endif %}</p>
        <p class="muted">Optional compatibility LLM report artifacts: <code>{{ l4_report.path }}</code>{% if l4_report.guardrail_path %}, <code>{{ l4_report.guardrail_path }}</code>{% endif %}.</p>
      </article>
      {% endif %}
      <div class="artifact-grid">
        {% for artifact in fixed_report.developer_artifacts.artifacts %}
        <a class="artifact-link" href="{{ artifact.path }}"><strong>{{ artifact.name }}</strong><code>{{ artifact.path }}</code></a>
        {% else %}
        <p>No developer artifacts were listed.</p>
        {% endfor %}
      </div>
    </section>

    <section id="evaluation-summary">
      <h2>Evaluation Summary</h2>
      {% if fixed_report.evaluation_summary.available %}
      <p>Evaluation status: {{ fixed_report.evaluation_summary.status }}</p>
      {% else %}
      <p>{{ fixed_report.evaluation_summary.message }}</p>
      {% endif %}
    </section>
  </main>
</body>
</html>
