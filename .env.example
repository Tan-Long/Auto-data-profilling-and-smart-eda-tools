# Copy to .env for optional local configuration. Leave values blank unless you
# explicitly enable the matching optional integration.

# Local web runner output directory. Docker Compose overrides this to
# /app/outputs/web_runs and mounts ./outputs from the host.
VSF_PROFILER_OUTPUT_DIR=outputs/web_runs

# Host port used by docker-compose.yml. The container still listens on 8765.
VSF_PROFILER_PORT=8765

# Optional LLM provider settings. The profiler still requires --use-llm or a
# selected issue enrichment action before any provider call is attempted.
VSF_PROFILER_LLM_PROVIDER=openai
OPENAI_API_KEY=

# Override model/client settings if your OpenAI-compatible endpoint requires it.
VSF_OPENAI_MODEL=gpt-5.4-mini
VSF_OPENAI_BASE_URL=https://api.openai.com/v1
VSF_OPENAI_TIMEOUT_SECONDS=60
VSF_OPENAI_MAX_OUTPUT_TOKENS=1200
